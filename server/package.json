{
  "name": "y02-server",
  "version": "1.0.0",
  "description": "AirViz — Backend API + Worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:worker\"",
    "dev:api": "node --watch src/server.js",
    "dev:worker": "node --watch worker/index.js",
    "seed": "node src/seed.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "supercluster": "^8.0.1"
  }
}
